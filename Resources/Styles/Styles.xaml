        BaseResourceKey="BaseLabelSecondaryStyle"
        TargetType="Label">
        <Setter Property="FontFamily" Value="LightFont" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="TextColor" Value="{StaticResource Gray600}" />
    </Style>

    <Style
        x:Key="LabelCardTitleStyle"
        BaseResourceKey="BaseLabelBodyStyle"
        TargetType="Label">
        <Setter Property="FontFamily" Value="SemiboldFont" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="TextColor" Value="{StaticResource Gray900}" />
    </Style>

    <Style x:Key="ShimmerViewStyle" TargetType="shimmer:ShimmerView">
        <Setter Property="ShapeType" Value="RoundedRectangle" />
    </Style>

    <Style x:Key="SfShimmerStyle" TargetType="shimmer:SfShimmer">
        <Setter Property="WaveColor" Value="{StaticResource Gray600}" />
        <Setter Property="AnimationDuration" Value="3000" />
        <Setter Property="VerticalOptions" Value="Fill" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style x:Key="InputLayoutStyleMobile" TargetType="syncfusion:SfTextInputLayout">
        <Setter Property="ContainerType" Value="Outlined" />
        <Setter Property="OutlineCornerRadius" Value="12" />
        <Setter Property="ContainerBackground" Value="Transparent" />
        <Setter Property="IsHintAlwaysFloated" Value="True" />
        <Setter Property="ReserveSpaceForAssistiveLabels" Value="False" />
        <Setter Property="LeadingViewPosition" Value="Outside" />
        <Setter Property="InputViewPadding" Value="14" />
        <Setter Property="HeightRequest" Value="{StaticResource InputFieldHeight}" />
        <Setter Property="HintLabelStyle">
            <syncfusion:LabelStyle
                FontFamily="RegularFont"
                FontSize="14"
                TextColor="{StaticResource Gray500}" />
        </Setter>
        <Setter Property="HelperLabelStyle">
            <syncfusion:LabelStyle
                FontFamily="LightFont"
                FontSize="12"
                TextColor="{StaticResource Gray500}" />
        </Setter>
        <Setter Property="ErrorLabelStyle">
            <syncfusion:LabelStyle
                FontFamily="LightFont"
                FontSize="12"
                TextColor="{StaticResource Danger}" />
        </Setter>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Stroke" Value="{StaticResource Gray300}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Focused">
                        <VisualState.Setters>
                            <Setter Property="Stroke" Value="{StaticResource Primary}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Error">
                        <VisualState.Setters>
                            <Setter Property="Stroke" Value="{StaticResource Danger}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="SearchBoxBorderStyle" TargetType="Border">
        <Setter Property="HeightRequest" Value="{StaticResource InputFieldHeight}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Stroke" Value="{StaticResource Gray300}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource Spacing14}" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="{StaticResource BorderRadiusLarge}" />
        </Setter>
    </Style>

    <Style
        x:Key="PopupStyle"
        ApplyToDerivedTypes="True"
        TargetType="{x:Type toolkit:Popup}">
        <Setter Property="BackgroundColor" Value="{StaticResource White}" />
    </Style>

    <Style x:Key="SegmentedTabStyle" TargetType="tabs:SegmentedTabItem">
        <Setter Property="SelectedTabColor" Value="{StaticResource Primary}" />
        <Setter Property="FontFamily" Value="RegularFont" />
        <Setter Property="LabelSize" Value="14" />
        <Setter Property="SelectedLabelColor" Value="{StaticResource White}" />
        <Setter Property="UnselectedLabelColor" Value="{StaticResource Gray600}" />
    </Style>

    <Style x:Key="SfSegmentedControlStyle" TargetType="segmented:SfSegmentedControl">
        <Setter Property="HeightRequest" Value="{StaticResource ButtonHeightLarge}" />
        <Setter Property="SegmentHeight" Value="{StaticResource ButtonHeightLarge}" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="CornerRadius" Value="{StaticResource BorderRadiusLarge}" />
        <Setter Property="SegmentCornerRadius" Value="{StaticResource BorderRadiusMedium}" />
        <Setter Property="Stroke" Value="{StaticResource Gray300}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="ShowSeparator" Value="False" />
        <Setter Property="SegmentTemplate">
            <DataTemplate x:DataType="segmented:SfSegmentItem">
                <Grid Padding="{StaticResource Spacing12}" BackgroundColor="{Binding IsSelected, Converter={toolkit:BoolToObjectConverter TrueObject={StaticResource Primary}, FalseObject={StaticResource White}}}">
                    <Label
                        HorizontalOptions="Center"
                        Style="{StaticResource LabelBodySemiboldStyle}"
                        Text="{Binding Text}"
                        TextColor="{Binding IsSelected, Converter={StaticResource SegmentTextColorConverter}}"
                        VerticalOptions="Center" />
                </Grid>
            </DataTemplate>
        </Setter>
    </Style>

    <Style x:Key="FileExtensionChipStyle" TargetType="chip:SfChip">
        <Setter Property="Padding" Value="{StaticResource ChipPaddingMedium}" />
        <Setter Property="Background" Value="{StaticResource PurpleLight}" />
        <Setter Property="CornerRadius" Value="{StaticResource BorderRadiusSmall}" />
        <Setter Property="FontFamily" Value="SemiboldFont" />
        <Setter Property="FontSize" Value="{StaticResource ChipFontSizeMedium}" />
        <Setter Property="HeightRequest" Value="{StaticResource ChipHeightMedium}" />
        <Setter Property="TextColor" Value="{StaticResource Purple}" />
        <Setter Property="Stroke" Value="{StaticResource Purple}" />
        <Setter Property="StrokeThickness" Value="1" />
    </Style>

    <Style
        x:Key="AuditLogActionChipStyle"
        BasedOn="{StaticResource FileExtensionChipStyle}"
        TargetType="chip:SfChip">
        <Setter Property="Background" Value="{StaticResource Gray100}" />
        <Setter Property="TextColor" Value="{StaticResource Gray700}" />
        <Setter Property="Stroke" Value="{StaticResource Gray200}" />
        <Setter Property="FontSize" Value="{StaticResource ChipFontSizeSmall}" />
        <Setter Property="Padding" Value="{StaticResource ChipPaddingSmall}" />
        <Setter Property="HeightRequest" Value="{StaticResource ChipHeightSmall}" />
    </Style>
</ResourceDictionary>