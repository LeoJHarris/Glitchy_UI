<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage
    x:Class="Glitchy_UI.Views.AuditLogPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:chip="clr-namespace:Syncfusion.Maui.Toolkit.Chips;assembly=Syncfusion.Maui.Toolkit"
    xmlns:controls="clr-namespace:Glitchy_UI.Controls"
    xmlns:fonts="clr-namespace:Glitchy_UI.Resources.Fonts"
    xmlns:groups="clr-namespace:Glitchy_UI.Groups"
    xmlns:helpers="clr-namespace:Glitchy_UI.Helpers"
    xmlns:shimmer="clr-namespace:Syncfusion.Maui.Toolkit.Shimmer;assembly=Syncfusion.Maui.Toolkit"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewmodels="clr-namespace:Glitchy_UI.ViewModels"
    xmlns:viewmodels1="clr-namespace:Glitchy_UI.Models.ViewModels"
    xmlns:views="clr-namespace:Glitchy_UI.Views"
    Title="Audit Log"
    x:DataType="viewmodels:AuditLogPageViewModel"
    BackgroundColor="{StaticResource PageBackground}">

    <views:BasePage.ToolbarItems>
        <ToolbarItem Command="{Binding OpenFilterBottomSheetCommand}">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="MaterialDesignIcons"
                    Glyph="{x:Static fonts:MaterialDesignIcons.FilterOutline}"
                    Size="{StaticResource IconSizeXLarge}"
                    Color="{StaticResource White}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </views:BasePage.ToolbarItems>

    <Grid RowDefinitions="Auto,*">
        <!--  Filter Active Indicator Panel  -->
        <Grid
            Grid.Row="0"
            IsVisible="{Binding HasActiveFilters}"
            RowDefinitions="Auto,Auto">
            <Border
                Grid.Row="0"
                Padding="{StaticResource AuditLogFilterPanelPadding}"
                BackgroundColor="{AppThemeBinding Light={StaticResource FilterPanelBackgroundLight},
                                                  Dark={StaticResource FilterPanelBackgroundDark}}"
                StrokeThickness="0">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="{StaticResource Spacing10}">
                    <Image Grid.Column="0" VerticalOptions="Center">
                        <Image.Source>
                            <FontImageSource
                                FontFamily="MaterialDesignIcons"
                                Glyph="{x:Static fonts:MaterialDesignIcons.FilterCheck}"
                                Size="{StaticResource IconSizeNormal}"
                                Color="{StaticResource Primary}" />
                        </Image.Source>
                    </Image>
                    <Label
                        Grid.Column="1"
                        Style="{StaticResource LabelSmallSemiboldStyle}"
                        Text="{Binding FilterSummary}"
                        TextColor="{StaticResource Primary}"
                        VerticalOptions="Center" />
                    <Border
                        Grid.Column="2"
                        Padding="{StaticResource AuditLogClearFiltersButtonPadding}"
                        BackgroundColor="{StaticResource Primary}"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{StaticResource BorderRadiusMedium}" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearFiltersCommand}" />
                        </Border.GestureRecognizers>
                        <Label
                            Style="{StaticResource LabelSmallSemiboldStyle}"
                            Text="Clear"
                            TextColor="{StaticResource White}"
                            VerticalOptions="Center" />
                    </Border>
                </Grid>
            </Border>

            <BoxView
                Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource FilterPanelStrokeLight},
                                                  Dark={StaticResource FilterPanelStrokeDark}}"
                HeightRequest="{StaticResource DividerThickness}"
                HorizontalOptions="Fill" />
        </Grid>

        <Grid Grid.Row="1" toolkit:StateContainer.CurrentState="{Binding CurrentPageState}">
            <toolkit:StateContainer.StateViews>
                <controls:ErrorView toolkit:StateView.StateKey="{x:Static helpers:StateKey.Error}" />

                <shimmer:SfShimmer toolkit:StateView.StateKey="{x:Static helpers:StateKey.Loading}" Style="{StaticResource SfShimmerStyle}">
                    <shimmer:SfShimmer.CustomView>
                        <Grid
                            Padding="{StaticResource Spacing16}"
                            BackgroundColor="{StaticResource PageBackground}"
                            RowDefinitions="*, auto">
                            <VerticalStackLayout Grid.Row="0" Spacing="{StaticResource Spacing14}">
                                <VerticalStackLayout Spacing="{StaticResource Spacing4}">
                                    <shimmer:ShimmerView
                                        HeightRequest="{StaticResource ShimmerHeightMedium}"
                                        HorizontalOptions="Start"
                                        Style="{StaticResource ShimmerViewStyle}"
                                        WidthRequest="{StaticResource WidthLarge}" />
                                    <shimmer:ShimmerView
                                        HeightRequest="{StaticResource ShimmerHeightSmall}"
                                        HorizontalOptions="Start"
                                        Style="{StaticResource ShimmerViewStyle}"
                                        WidthRequest="{StaticResource WidthSmall}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="{StaticResource Spacing10}">
                                    <shimmer:ShimmerView HeightRequest="{StaticResource ShimmerHeightLarge}" Style="{StaticResource ShimmerViewStyle}" />
                                    <shimmer:ShimmerView HeightRequest="{StaticResource ShimmerHeightLarge}" Style="{StaticResource ShimmerViewStyle}" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                            <shimmer:ShimmerView
                                Grid.Row="1"
                                HeightRequest="{StaticResource ButtonHeightXLarge}"
                                HorizontalOptions="Center"
                                Style="{StaticResource ShimmerViewStyle}"
                                VerticalOptions="End"
                                WidthRequest="{StaticResource WidthXLarge}" />
                        </Grid>
                    </shimmer:SfShimmer.CustomView>
                </shimmer:SfShimmer>

                <RefreshView
                    toolkit:StateView.StateKey="{x:Static helpers:StateKey.Success}"
                    Command="{Binding PullToRefreshPageCommand}"
                    IsRefreshing="{Binding IsRefreshing}">
                    <CollectionView
                        BackgroundColor="{StaticResource PageBackground}"
                        IsGrouped="True"
                        ItemsSource="{Binding AuditLogs}">
                        <CollectionView.Header>
                            <ContentView>
                                <Label
                                    Margin="16,16,16,0"
                                    Style="{StaticResource LabelBodySemiboldStyle}"
                                    Text="This is Tab 3"
                                    TextColor="{StaticResource Gray600}" />
                            </ContentView>
                        </CollectionView.Header>
                        <CollectionView.Footer>
                            <ContentView />
                        </CollectionView.Footer>
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="{StaticResource Spacing10}" Orientation="Vertical" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <Grid Padding="{StaticResource Spacing24}" RowDefinitions="*,Auto,*">
                                <VerticalStackLayout
                                    Grid.Row="1"
                                    HorizontalOptions="Center"
                                    Spacing="{StaticResource Spacing14}"
                                    VerticalOptions="Center">
                                    <Border
                                        BackgroundColor="{StaticResource BlackTransparent0D}"
                                        HeightRequest="{StaticResource AvatarSizeXXLarge}"
                                        HorizontalOptions="Center"
                                        StrokeShape="RoundRectangle 28"
                                        StrokeThickness="0"
                                        WidthRequest="{StaticResource AvatarSizeXXLarge}">
                                        <Image HorizontalOptions="Center" VerticalOptions="Center">
                                            <Image.Source>
                                                <FontImageSource
                                                    FontFamily="MaterialDesignIcons"
                                                    Glyph="{x:Static fonts:MaterialDesignIcons.ClipboardTextOutline}"
                                                    Size="{StaticResource IconSizeHero}"
                                                    Color="{StaticResource PrimaryDarkText}" />
                                            </Image.Source>
                                        </Image>
                                    </Border>

                                    <Label
                                        HorizontalOptions="Center"
                                        HorizontalTextAlignment="Center"
                                        Style="{StaticResource LabelLargeSemiboldStyle}"
                                        Text="No audit logs"
                                        TextColor="{StaticResource PrimaryDarkText}" />

                                    <Label
                                        HorizontalOptions="Center"
                                        HorizontalTextAlignment="Center"
                                        Style="{StaticResource LabelBodyRegularStyle}"
                                        Text="Try adjusting filters or pull down to refresh."
                                        TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>
                            </Grid>
                        </CollectionView.EmptyView>

                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate x:DataType="groups:IAuditLogGrouped">
                                <Grid Padding="{StaticResource AuditLogGroupHeaderPadding}" BackgroundColor="{StaticResource PageBackground}">
                                    <Label
                                        Style="{StaticResource LabelBodySemiboldStyle}"
                                        Text="{Binding Date, StringFormat='{0:dd MMM yyyy}'}"
                                        TextColor="{StaticResource Gray600}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels1:AuditLogViewModel">
                                <Border
                                    Margin="{StaticResource AuditLogItemMargin}"
                                    Padding="{StaticResource Spacing16}"
                                    BackgroundColor="{StaticResource White}"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{StaticResource BorderRadiusLarge}" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow
                                            Brush="{StaticResource ShadowStrong}"
                                            Opacity="0.5"
                                            Radius="0.9"
                                            Offset="0,2" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenAuditLogDetailCommand}" CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid
                                        ColumnDefinitions="*,Auto"
                                        ColumnSpacing="{StaticResource Spacing10}"
                                        RowDefinitions="Auto,Auto"
                                        RowSpacing="{StaticResource Spacing10}">
                                        <Label
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Style="{StaticResource LabelBodySemiboldStyle}"
                                            TextColor="{StaticResource Gray900}"
                                            VerticalOptions="Center">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding SiteName, Converter={StaticResource EmptyStringToPlaceholderConverter}}" />
                                                    <Span Text=" • " />
                                                    <Span Text="{Binding AppName, Converter={StaticResource EmptyStringToPlaceholderConverter}}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>

                                        <Label
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            HorizontalOptions="End"
                                            Style="{StaticResource LabelSecondaryRegularStyle}"
                                            Text="{Binding LogDate, Converter={StaticResource DateTimeOffsetToLocalStringConverter}, ConverterParameter='dd MMM h:mm tt'}"
                                            TextColor="{StaticResource Gray600}"
                                            VerticalOptions="Center" />

                                        <Label
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            IsVisible="{Binding IpAddress, Converter={StaticResource IsNotEmptyStringConverter}}"
                                            Style="{StaticResource LabelSmallLightStyle}"
                                            Text="{Binding IpAddress}"
                                            TextColor="{StaticResource Gray500}"
                                            VerticalOptions="Center" />

                                        <chip:SfChip
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            HorizontalOptions="End"
                                            Style="{StaticResource AuditLogActionChipStyle}"
                                            Text="{Binding ActionDisplay}"
                                            VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </toolkit:StateContainer.StateViews>
        </Grid>
    </Grid>
</views:BasePage>