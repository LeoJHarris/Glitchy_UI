<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Glitchy_UI.Controls.ErrorView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Controls="clr-namespace:Glitchy_UI.Controls"
    x:Name="this"
    x:DataType="Controls:ErrorView">
    <ContentView.Content>
        <VerticalStackLayout
            Margin="16"
            Spacing="16"
            VerticalOptions="Center">
            <Label
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="{Binding Message, Source={x:Reference this}}" />
            <Button
                Command="{Binding RefreshCommand, Source={x:Reference this}}"
                Text="Try again"
                VerticalOptions="End" />
        </VerticalStackLayout>
    </ContentView.Content>
</ContentView>